#!/bin/bash
# YUNSH OS Boot Splash
# Shows YUNSH logo on framebuffer during boot
# Pure bash, no external dependencies

FB_DEV="/dev/fb0"
SPLASH_FILE="/boot/yunsh-splash.raw"

# Wait for framebuffer
for i in $(seq 1 30); do
    [ -c "$FB_DEV" ] && break
    sleep 0.1
done

# Write splash to framebuffer
if [ -f "$SPLASH_FILE" ]; then
    cat "$SPLASH_FILE" > "$FB_DEV" 2>/dev/null || true
elif [ -f "/boot/yunsh-splash-1080p.bmp" ]; then
    # Fallback: use Python3 to parse BMP if available
    command -v python3 >/dev/null 2>&1 && python3 -c "
import sys, struct
path = '/boot/yunsh-splash-1080p.bmp'
with open(path, 'rb') as f:
    d = f.read()
off = struct.unpack('<I', d[10:14])[0]
w = struct.unpack('<i', d[18:22])[0]
h = abs(struct.unpack('<i', d[22:26])[0])
bpp = struct.unpack('<H', d[28:30])[0]
row = ((bpp * w + 31)//32)*4
out = bytearray(w*h*4)
for y in range(h):
    sy = h-1-y
    for x in range(w):
        po = off + sy*row + x*(bpp//8)
        r, g, b = d[po+2], d[po+1], d[po]
        pi = (y*w + x)*4
        out[pi:pi+4] = bytes([b, g, r, 0])
sys.stdout.buffer.write(out)
" > "$FB_DEV" 2>/dev/null || true
fi

exit 0
