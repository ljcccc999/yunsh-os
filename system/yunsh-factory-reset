#!/bin/bash
# YUNSH OS v1.0 - Factory Reset
# Resets to factory state: keeps system, removes all user data

set -e

echo "YUNSH OS v1.0 - Factory Reset"
echo ""

# ─── Remove activation flag (shows wizard on next boot) ───
rm -f /etc/yunsh/.activated
echo "✓ 激活状态已重置"

# ─── Keep system packages flag (don't reinstall) ───
# /etc/yunsh/.packages_installed is preserved

# ─── Wipe user configurations (Wi-Fi, language, Bluetooth) ───
rm -f /etc/yunsh/*.conf 2>/dev/null || true
echo "✓ 配置已清除"

# ─── Delete user accounts (created during activation) ───
for userdir in /home/*; do
    username=$(basename "$userdir")
    if [ "$username" != "root" ] && [ -d "$userdir" ]; then
        userdel -r "$username" 2>/dev/null || true
    fi
done
echo "✓ 用户账号已删除"

# ─── Clear caches and temp ───
rm -rf /root/.cache 2>/dev/null || true
rm -rf /tmp/* 2>/dev/null || true
echo "✓ 缓存已清理"

# ─── Clear logs ───
: > /var/log/yunsh-update.log 2>/dev/null || true
: > /var/log/yunsh-network.log 2>/dev/null || true
: > /var/log/yunsh-bluetooth.log 2>/dev/null || true
echo "✓ 日志已清理"

# ─── Waydroid user data ───
if command -v waydroid &>/dev/null; then
    waydroid session stop 2>/dev/null || true
fi
rm -rf /var/lib/waydroid/data/* 2>/dev/null || true
echo "✓ Waydroid 数据已清理"

echo ""
echo "✅ 恢复出厂设置完成！"
echo "系统将重启并进入激活向导"
echo ""

sleep 2
reboot
