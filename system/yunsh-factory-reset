#!/bin/bash
# YUNSH OS v1.0 - Factory Reset
# Clears user data and caches, KEEPS activation state + settings

set -e

echo "YUNSH OS v1.0 - Factory Reset"

# Keep activation state (no re-activation needed after reset)
# NOT removing: /etc/yunsh/.activated
# NOT removing: /etc/yunsh/.packages_installed

# Keep user settings (language, Wi-Fi config, etc.)
# NOT removing: /etc/yunsh/*.conf

# Clear user caches and temp data
rm -rf /home/* 2>/dev/null || true
rm -rf /root/.cache 2>/dev/null || true
rm -rf /tmp/yunsh-* 2>/dev/null || true

# Clear logs
: > /var/log/yunsh-update.log 2>/dev/null || true
: > /var/log/yunsh-network.log 2>/dev/null || true
: > /var/log/yunsh-bluetooth.log 2>/dev/null || true

# Waydroid user data (apps, settings)
waydroid session stop 2>/dev/null || true
rm -rf /var/lib/waydroid/data/* 2>/dev/null || true

echo "✅ Factory reset complete!"
echo "Rebooting..."

sleep 2
reboot
