#!/usr/bin/env python3
"""
YUNSH BNO085 I2C Reader — direct to Pi GPIO, no ESP32 needed.
Reads hardware-fused rotation vectors (quaternion → yaw/pitch/roll).

Connection (Pi GPIO → BNO085):
  Pin 3 (SDA)  → SDA
  Pin 5 (SCL)  → SCL
  Pin 1 (3.3V) → VCC
  Pin 9 (GND)  → GND

BNO085 has built-in sensor fusion — outputs ready-to-use orientation.
No software filter needed.
"""

import smbus2
import struct
import socket
import time
import json
import math
import sys

# BNO085 I2C address (AD0=LOW = 0x4A, AD0=HIGH = 0x4B)
BNO085_ADDR = 0x4A

# SHTP channel IDs
CHANNEL_COMMAND = 0
CHANNEL_EXECUTABLE = 1
CHANNEL_CONTROL = 2
CHANNEL_INPUT_SENSOR_REPORT = 3
CHANNEL_OUTPUT_SENSOR_REPORT = 4
CHANNEL_WAKE_INPUT_SENSOR_REPORT = 5
CHANNEL_WAKE_OUTPUT_SENSOR_REPORT = 6
CHANNEL_GYRO = 8

# Sensor report IDs
SENSOR_REPORTID_GAME_ROTATION_VECTOR = 0x08
SENSOR_REPORTID_ROTATION_VECTOR = 0x05
SENSOR_REPORTID_ACCELEROMETER = 0x01
SENSOR_REPORTID_GYROSCOPE = 0x02
SENSOR_REPORTID_MAGNETIC_FIELD = 0x03
SENSOR_REPORTID_LINEAR_ACCEL = 0x04
SENSOR_REPORTID_GRAVITY = 0x06

# FRS (File Record System) IDs
FRS_RECORDID_ACCEL_RANGE = 0xE302

# Command request
COMMAND_REQUEST = 0xF1
COMMAND_RESPONSE = 0xF1

# Execute command
EXECUTE_COMMAND_REQUEST = 0x83
EXECUTE_COMMAND_RESPONSE = 0x83

# Tare command
TARE_COMMAND = 0x06
TARE_NOW = 0x02  # Set current orientation as reference


class SHTPPacket:
    """Simple SHTP packet builder/parser."""

    def __init__(self, channel=0, sequence=0, data=b""):
        self.channel = channel
        self.sequence = sequence
        self.data = data

    def encode(self):
        """Encode to bytes for I2C write."""
        length = len(self.data)
        header = struct.pack("<HB", length + 4, (self.channel << 4) | self.sequence)
        return header + self.data

    @staticmethod
    def parse(data):
        """Parse SHTP header from raw I2C read data."""
        if len(data) < 4:
            return None
        length = struct.unpack("<H", data[0:2])[0]
        channel_seq = data[3]
        channel = (channel_seq >> 4) & 0xF
        sequence = channel_seq & 0xF
        payload = data[4:length] if len(data) >= length else b""
        return SHTPPacket(channel, sequence, payload)


class BNO085:
    def __init__(self, bus=1, addr=BNO085_ADDR):
        self.bus = smbus2.SMBus(bus)
        self.addr = addr
        self.sequence = [0] * 8  # sequence per channel
        self._init_sensor()

    def _write_shtp(self, channel, data):
        """Write SHTP packet to BNO085."""
        seq = self.sequence[channel]
        packet = SHTPPacket(channel, seq, data)
        self.sequence[channel] = (seq + 1) & 0x0F
        raw = packet.encode()
        self.bus.write_i2c_block_data(self.addr, 0, list(raw))
        time.sleep(0.001)

    def _read_shtp(self, timeout=0.5):
        """Read SHTP packet from BNO085 (blocking)."""
        deadline = time.time() + timeout
        while time.time() < deadline:
            try:
                # First read header (4 bytes)
                header = self.bus.read_i2c_block_data(self.addr, 0, 4)
                length = struct.unpack("<H", bytes(header[0:2]))[0]
                if length > 4:
                    remaining = length - 4
                    if remaining > 0:
                        rest = self.bus.read_i2c_block_data(self.addr, 0, remaining)
                        header.extend(rest)
                return SHTPPacket.parse(bytes(header))
            except OSError:
                time.sleep(0.005)
        return None

    def _send_sensor_report_request(self, sensor_id, report_interval_us=20000):
        """Enable a sensor report with given interval (20ms = 50Hz default)."""
        # Enable sensor report command
        data = struct.pack(
            "<BBBBII",
            EXECUTE_COMMAND_REQUEST,
            sensor_id,
            0x01,  # report type: on-change
            # For rotation vectors, use 0x01 (on-change) for efficient updates
            0x01,  # report interval in units of 100µs? No...
        )
        # Actually the format is different. Let me use the proper binary format.
        # Length of payload: 1 + 1 + 1 + 1 + 4 + 4 = 12
        payload = struct.pack(
            "<BBBBI",
            0xF9,  # Enable report
            sensor_id,
            0x01,  # Report type (0x01 = on-change)
            0x00,  # Reserved
            report_interval_us,
        )
        # Send on channel 3 (input sensor report)
        self._write_shtp(CHANNEL_INPUT_SENSOR_REPORT, payload)
        time.sleep(0.05)

    def _init_sensor(self):
        """Initialize BNO085 and enable rotation vector reports."""
        print("[bno085] Initializing...", file=sys.stderr)

        # Drain any stale packets
        for _ in range(5):
            try:
                self.bus.read_i2c_block_data(self.addr, 0, 4)
            except:
                pass
            time.sleep(0.01)

        # Enable game rotation vector (no mag, heading drifts slowly)
        # Use 20ms interval = 50Hz
        self._send_sensor_report_request(SENSOR_REPORTID_GAME_ROTATION_VECTOR, 20000)

        # Also enable regular rotation vector for mag-stabilized heading
        # if magnetometer is present (BNO085 includes one)
        self._send_sensor_report_request(SENSOR_REPORTID_ROTATION_VECTOR, 20000)

        print("[bno085] Ready — outputting rotation at ~50Hz", file=sys.stderr)

    def read_rotation(self):
        """Read latest rotation quaternion from BNO085.
        Returns: (i, j, k, real) or None if no data available.
        """
        packet = self._read_shtp(timeout=0.05)
        if packet is None:
            return None

        if packet.channel != CHANNEL_OUTPUT_SENSOR_REPORT:
            return None

        data = packet.data
        if len(data) < 4:
            return None

        report_id = data[0]
        if report_id not in (SENSOR_REPORTID_ROTATION_VECTOR,
                             SENSOR_REPORTID_GAME_ROTATION_VECTOR):
            return None

        # Rotation vector report: 18 bytes
        # real(i), real(j), real(k), real(real)... each Q14.2 fixed point
        if len(data) < 18:
            return None

        # Parse: bytes 4-17 contain quaternion as 4 Q14 values
        q_i = struct.unpack("<h", bytes(data[4:6]))[0] / 16384.0
        q_j = struct.unpack("<h", bytes(data[6:8]))[0] / 16384.0
        q_k = struct.unpack("<h", bytes(data[8:10]))[0] / 16384.0
        q_real = struct.unpack("<h", bytes(data[10:12]))[0] / 16384.0

        # Accuracy (rotation vector only, not game)
        accuracy = data[17] if len(data) > 17 else 3

        return {
            "quat": (q_i, q_j, q_k, q_real),
            "accuracy": accuracy,
            "report_id": report_id,
        }

    def quat_to_euler(self, quat):
        """Convert quaternion (i, j, k, real) to yaw/pitch/roll in degrees."""
        qx, qy, qz, qw = quat

        # Roll (x-axis rotation)
        roll = math.atan2(2.0 * (qw * qx + qy * qz), 1.0 - 2.0 * (qx * qx + qy * qy))

        # Pitch (y-axis rotation)
        sinp = 2.0 * (qw * qy - qz * qx)
        sinp = max(-1.0, min(1.0, sinp))
        pitch = math.asin(sinp)

        # Yaw (z-axis rotation)
        yaw = math.atan2(2.0 * (qw * qz + qx * qy), 1.0 - 2.0 * (qy * qy + qz * qz))

        return {
            "yaw": yaw * (180.0 / math.pi),
            "pitch": pitch * (180.0 / math.pi),
            "roll": roll * (180.0 / math.pi),
        }

    def tare_now(self):
        """Set current orientation as zero reference (tare)."""
        payload = struct.pack("<BBB", EXECUTE_COMMAND_REQUEST, TARE_COMMAND, TARE_NOW)
        self._write_shtp(CHANNEL_CONTROL, payload)
        print("[bno085] Tare set", file=sys.stderr)

    def close(self):
        self.bus.close()


def main():
    print("[bno085-reader] Starting BNO085 → yunsh-headtracking bridge", file=sys.stderr)

    try:
        bno = BNO085()
    except Exception as e:
        print(f"[bno085-reader] ERROR: {e}", file=sys.stderr)
        print("[bno085-reader] Check wiring: BNO085 SDA→GPIO3 SCL→GPIO5 3.3V→Pin1 GND→Pin9", file=sys.stderr)
        sys.exit(1)

    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    last_yaw, last_pitch, last_roll = 0, 0, 0
    consecutive_errors = 0

    while True:
        try:
            result = bno.read_rotation()

            if result is not None:
                euler = bno.quat_to_euler(result["quat"])
                data = {
                    "yaw": round(euler["yaw"], 2),
                    "pitch": round(euler["pitch"], 2),
                    "roll": round(euler["roll"], 2),
                }
                # Only send if changed significantly (reduce network noise)
                if (abs(data["yaw"] - last_yaw) > 0.1 or
                    abs(data["pitch"] - last_pitch) > 0.1 or
                    abs(data["roll"] - last_roll) > 0.1):
                    sock.sendto(json.dumps(data).encode(), ("127.0.0.1", 8595))
                    last_yaw = data["yaw"]
                    last_pitch = data["pitch"]
                    last_roll = data["roll"]
                consecutive_errors = 0
            else:
                consecutive_errors += 1
                if consecutive_errors > 100:
                    print("[bno085-reader] WARNING: No data from sensor", file=sys.stderr)
                    consecutive_errors = 0

            time.sleep(0.01)  # ~100Hz polling loop

        except KeyboardInterrupt:
            break
        except Exception as e:
            print(f"[bno085-reader] Error: {e}", file=sys.stderr)
            time.sleep(0.1)

    bno.close()
    sock.close()
    print("[bno085-reader] Stopped", file=sys.stderr)


if __name__ == "__main__":
    main()
