#!/usr/bin/env python3
"""
YUNSH ICM-20948 I2C Reader — direct IMU to Pi, no ESP32 needed.
Reads 9-axis data via Raspberry Pi GPIO (I2C), sends to headtracking daemon.

Connection (Pi GPIO → ICM-20948):
  Pin 3 (SDA)  → SDA
  Pin 5 (SCL)  → SCL
  Pin 1 (3.3V) → VCC
  Pin 9 (GND)  → GND
"""
import smbus2
import math
import struct
import socket
import time
import json

ICM_ADDR = 0x68  # AD0 low (default)
ICM_MAG_ADDR = 0x0C  # AK09916 magnetometer on same bus

# Registers
REG_WHOAMI    = 0x00
REG_PWR_MGMT1 = 0x06
REG_ACCEL     = 0x2D  # 6 bytes: accel X, Y, Z
REG_GYRO      = 0x33  # 6 bytes: gyro  X, Y, Z
REG_TEMP      = 0x39
REG_ACCEL_CFG = 0x14
REG_GYRO_CFG  = 0x01
REG_USER_CTRL = 0x03
REG_LP_CONFIG = 0x05

# Magnetometer (AK09916)
MAG_WIA  = 0x01
MAG_ST1  = 0x10
MAG_HXL  = 0x11  # 6 bytes: mag X, Y, Z
MAG_ST2  = 0x18
MAG_CNTL2 = 0x31
MAG_CNTL3 = 0x32

# Gyro scale: ±2000°/s
GYRO_SCALE = 2000.0 / 32768.0
# Accel scale: ±4g
ACCEL_SCALE = 4.0 / 32768.0
# Mag scale: ±4912µT / 32768
MAG_SCALE = 4912.0 / 32768.0


class ICM20948:
    def __init__(self, bus=1):
        self.bus = smbus2.SMBus(bus)
        self._init_sensor()
        # Quaternion filter state
        self.q = [1.0, 0.0, 0.0, 0.0]
        # Beta tuning: higher = more gyro trust, lower = more accel/mag trust
        self.beta = 0.1

    def _write_reg(self, addr, reg, val):
        self.bus.write_byte_data(addr, reg, val)

    def _read_regs(self, addr, reg, length):
        return self.bus.read_i2c_block_data(addr, reg, length)

    def _init_sensor(self):
        whoami = self._read_regs(ICM_ADDR, REG_WHOAMI, 1)[0]
        print(f"[icm] WHOAMI: 0x{whoami:02X} (expected 0xEA)")
        if whoami != 0xEA:
            raise RuntimeError(f"ICM-20948 not found at 0x{ICM_ADDR:02X}")

        # Wake up (clear sleep bit)
        self._write_reg(ICM_ADDR, REG_PWR_MGMT1, 0x01)
        time.sleep(0.01)

        # Gyro ±2000 dps, low-pass filter
        self._write_reg(ICM_ADDR, REG_GYRO_CFG, 0x06)  # ±2000
        # Accel ±4g
        self._write_reg(ICM_ADDR, REG_ACCEL_CFG, 0x02)

        # Enable I2C master for magnetometer passthrough
        self._write_reg(ICM_ADDR, REG_USER_CTRL, 0x20)

        # Init AK09916 magnetometer
        self._init_magnetometer()

    def _init_magnetometer(self):
        wia = self._read_regs(ICM_MAG_ADDR, MAG_WIA, 1)[0]
        print(f"[icm] MAG WIA: 0x{wia:02X} (expected 0x48)")
        if wia != 0x48:
            print("[icm] Magnetometer not detected, continuing without...")
            self.has_mag = False
            return
        self.has_mag = True
        # Set to continuous measurement mode 2 (100Hz)
        self._write_reg(ICM_MAG_ADDR, MAG_CNTL2, 0x08)
        time.sleep(0.01)

    def _read_magnetometer(self):
        if not self.has_mag:
            return (0, 0, 0)
        st1 = self._read_regs(ICM_MAG_ADDR, MAG_ST1, 1)[0]
        if not (st1 & 0x01):
            return (0, 0, 0)
        data = self._read_regs(ICM_MAG_ADDR, MAG_HXL, 6)
        x = struct.unpack('<h', bytes(data[0:2]))[0]
        y = struct.unpack('<h', bytes(data[2:4]))[0]
        z = struct.unpack('<h', bytes(data[4:6]))[0]
        return (x * MAG_SCALE, y * MAG_SCALE, z * MAG_SCALE)

    def read_sensors(self):
        # Read accel (6 bytes)
        accel_raw = self._read_regs(ICM_ADDR, REG_ACCEL, 6)
        ax = struct.unpack('<h', bytes(accel_raw[0:2]))[0] * ACCEL_SCALE
        ay = struct.unpack('<h', bytes(accel_raw[2:4]))[0] * ACCEL_SCALE
        az = struct.unpack('<h', bytes(accel_raw[4:6]))[0] * ACCEL_SCALE

        # Read gyro (6 bytes)
        gyro_raw = self._read_regs(ICM_ADDR, REG_GYRO, 6)
        gx = struct.unpack('<h', bytes(gyro_raw[0:2]))[0] * GYRO_SCALE * (math.pi / 180)
        gy = struct.unpack('<h', bytes(gyro_raw[2:4]))[0] * GYRO_SCALE * (math.pi / 180)
        gz = struct.unpack('<h', bytes(gyro_raw[4:6]))[0] * GYRO_SCALE * (math.pi / 180)

        # Read temperature
        temp_raw = self._read_regs(ICM_ADDR, REG_TEMP, 2)
        temp = struct.unpack('<h', bytes(temp_raw))[0] / 333.87 + 21

        # Read magnetometer
        mx, my, mz = self._read_magnetometer()

        # Madgwick filter for orientation
        self._madgwick_update(gx, gy, gz, ax, ay, az, mx, my, mz)

        # Convert quaternion → yaw/pitch/roll (degrees)
        q0, q1, q2, q3 = self.q
        roll  = math.atan2(2*(q0*q1 + q2*q3), 1 - 2*(q1*q1 + q2*q2)) * (180/math.pi)
        pitch = math.asin(2*(q0*q2 - q3*q1)) * (180/math.pi)
        yaw   = math.atan2(2*(q0*q3 + q1*q2), 1 - 2*(q2*q2 + q3*q3)) * (180/math.pi)

        return {"yaw": yaw, "pitch": pitch, "roll": roll, "temp": temp}

    def _madgwick_update(self, gx, gy, gz, ax, ay, az, mx, my, mz, dt=0.01):
        """Madgwick orientation filter (simplified)."""
        q0, q1, q2, q3 = self.q
        beta = self.beta

        # Normalise accelerometer measurement
        norm = math.sqrt(ax*ax + ay*ay + az*az)
        if norm < 0.001: return
        ax /= norm; ay /= norm; az /= norm

        # Objective function and Jacobian for accel
        f1 = 2*(q1*q3 - q0*q2) - ax
        f2 = 2*(q0*q1 + q2*q3) - ay
        f3 = 2*(0.5 - q1*q1 - q2*q2) - az

        J_11or24 = 2*q2
        J_12or23 = 2*q3
        J_13or22 = 2*q0
        J_14or21 = 2*q1

        # Gradient descent step
        s0 = J_14or21 * f2 - J_11or24 * f1
        s1 = J_12or23 * f1 + J_13or22 * f2 - J_14or21 * f3
        s2 = J_12or23 * f2 - J_11or24 * f1 - J_13or22 * f3
        s3 = J_12or23 * f3 - J_14or21 * f2

        norm_s = math.sqrt(s0*s0 + s1*s1 + s2*s2 + s3*s3)
        if norm_s > 0.001:
            s0 /= norm_s; s1 /= norm_s; s2 /= norm_s; s3 /= norm_s

        # Apply step
        q0 -= beta * s0 * dt
        q1 -= beta * s1 * dt
        q2 -= beta * s2 * dt
        q3 -= beta * s3 * dt

        # Integrate gyroscope
        q0 += 0.5 * (-q1*gx - q2*gy - q3*gz) * dt
        q1 += 0.5 * ( q0*gx + q2*gz - q3*gy) * dt
        q2 += 0.5 * ( q0*gy - q1*gz + q3*gx) * dt
        q3 += 0.5 * ( q0*gz + q1*gy - q2*gx) * dt

        # Normalise quaternion
        norm_q = math.sqrt(q0*q0 + q1*q1 + q2*q2 + q3*q3)
        if norm_q > 0.001:
            q0 /= norm_q; q1 /= norm_q; q2 /= norm_q; q3 /= norm_q

        self.q = [q0, q1, q2, q3]

    def close(self):
        self.bus.close()


def main():
    import sys
    print("[icm-reader] Starting ICM-20948 -> yunsh-headtracking bridge", file=sys.stderr)

    try:
        icm = ICM20948()
    except Exception as e:
        print(f"[icm-reader] ERROR: {e}", file=sys.stderr)
        sys.exit(1)

    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)

    while True:
        try:
            data = icm.read_sensors()
            sock.sendto(json.dumps(data).encode(), ("127.0.0.1", 8595))
            time.sleep(0.01)  # ~100Hz
        except KeyboardInterrupt:
            break
        except Exception as e:
            print(f"[icm-reader] Error: {e}", file=sys.stderr)
            time.sleep(0.1)

    icm.close()
    sock.close()
    print("[icm-reader] Stopped", file=sys.stderr)


if __name__ == "__main__":
    main()
